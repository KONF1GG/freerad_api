{
  "dashboard": {
    "id": null,
    "title": "RADIUS Core - Мониторинг /acct и /authorize",
    "tags": ["radius", "acct", "authorize", "monitoring"],
    "style": "dark",
    "timezone": "browser",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "10s",
    "templating": {
      "list": [
        {
          "allValue": null,
          "current": {
            "isNone": true,
            "selected": false,
            "text": "Prometheus",
            "value": "prometheus"
          },
          "hide": 0,
          "includeAll": false,
          "label": "Источник данных",
          "multi": false,
          "name": "datasource",
          "options": [],
          "query": "prometheus",
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "type": "datasource"
        },
        {
          "allValue": ".*",
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "definition": "label_values(http_requests_total, instance)",
          "hide": 0,
          "includeAll": true,
          "label": "Инстанс",
          "multi": true,
          "name": "instance",
          "options": [],
          "query": {
            "query": "label_values(http_requests_total, instance)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "sort": 0,
          "type": "query"
        },
        {
          "allValue": "/acct/|/authorize/",
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          },
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "definition": "label_values(http_requests_total{path=~\"/(acct|authorize)/\"}, path)",
          "hide": 0,
          "includeAll": true,
          "label": "Endpoint",
          "multi": true,
          "name": "endpoint",
          "options": [],
          "query": {
            "query": "label_values(http_requests_total{path=~\"/(acct|authorize)/\"}, path)",
            "refId": "StandardVariableQuery"
          },
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "sort": 0,
          "type": "query"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "📊 Обзор Системы",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Активные HTTP Запросы",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(http_requests_active{instance=~\"$instance\", path=~\"$endpoint\"})",
            "legendFormat": "Всего",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Общий RPS",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m]))",
            "legendFormat": "Запросов/сек",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 10}
              ]
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 4,
        "title": "Средняя Задержка",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "Медиана",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.5}
              ]
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 5,
        "title": "Успешность Запросов",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(rate(http_responses_total{status_class=\"2\", instance=~\"$instance\", path=~\"$endpoint\"}[5m])) / sum(rate(http_responses_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m])) * 100",
            "legendFormat": "Успешных %",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 99}
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 6,
        "title": "🔀 Сравнение Endpoint'ов",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
        "collapsed": false
      },
      {
        "id": 7,
        "title": "RPS по Endpoint'ам",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum by (path) (rate(http_requests_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m]))",
            "legendFormat": "{{path}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "none",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Сравнение Времени Ответа",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (path, le) (rate(http_request_duration_seconds_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "95% {{path}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum by (path, le) (rate(http_request_duration_seconds_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "50% {{path}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "none",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
            }
          }
        }
      },
      {
        "id": 9,
        "title": "📈 Детальная Аналитика",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
        "collapsed": false
      },
      {
        "id": 10,
        "title": "HTTP Статус Коды",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum by (status_class, path) (rate(http_responses_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m]))",
            "legendFormat": "{{status_class}}xx {{path}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "normal",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Размер Ответов",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (path, le) (rate(http_response_size_bytes_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "95% {{path}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum by (path, le) (rate(http_response_size_bytes_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "50% {{path}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "none",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Активные Запросы",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum by (path) (http_requests_active{instance=~\"$instance\", path=~\"$endpoint\"})",
            "legendFormat": "{{path}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "none",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
            }
          }
        }
      },
      {
        "id": 13,
        "title": "🎯 Производительность по Endpoint'ам",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
        "collapsed": false
      },
      {
        "id": 14,
        "title": "/acct/ - Метрики",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 24},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{path=\"/acct/\", instance=~\"$instance\"}[5m]))",
            "legendFormat": "RPS",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{path=\"/acct/\", instance=~\"$instance\"}[5m])))",
            "legendFormat": "95% Latency",
            "refId": "B"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "mappings": []
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "RPS"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "reqps"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "95% Latency"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 15,
        "title": "/authorize/ - Метрики",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 24},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{path=\"/authorize/\", instance=~\"$instance\"}[5m]))",
            "legendFormat": "RPS",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{path=\"/authorize/\", instance=~\"$instance\"}[5m])))",
            "legendFormat": "95% Latency",
            "refId": "B"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "horizontal",
          "textMode": "value_and_name",
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "mappings": []
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "RPS"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "reqps"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "95% Latency"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 16,
        "title": "Сравнительная Таблица",
        "type": "table",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 24},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum by (path) (rate(http_requests_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m]))",
            "legendFormat": "RPS",
            "refId": "A",
            "format": "table",
            "instant": true
          },
          {
            "expr": "histogram_quantile(0.50, sum by (path, le) (rate(http_request_duration_seconds_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "Median Latency",
            "refId": "B",
            "format": "table",
            "instant": true
          },
          {
            "expr": "histogram_quantile(0.95, sum by (path, le) (rate(http_request_duration_seconds_bucket{instance=~\"$instance\", path=~\"$endpoint\"}[5m])))",
            "legendFormat": "95% Latency",
            "refId": "C",
            "format": "table",
            "instant": true
          },
          {
            "expr": "sum by (path) (rate(http_responses_total{status_class=\"2\", instance=~\"$instance\", path=~\"$endpoint\"}[5m])) / sum by (path) (rate(http_responses_total{instance=~\"$instance\", path=~\"$endpoint\"}[5m])) * 100",
            "legendFormat": "Success Rate",
            "refId": "D",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "job": true,
                "instance": true,
                "le": true
              },
              "indexByName": {},
              "renameByName": {
                "path": "Endpoint",
                "Value #A": "RPS",
                "Value #B": "Медиана (с)",
                "Value #C": "95% (с)",
                "Value #D": "Успешность (%)"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "cellOptions": {
                "type": "auto"
              },
              "inspect": false
            },
            "mappings": []
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "RPS"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "reqps"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Медиана (с)"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "95% (с)"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "s"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Успешность (%)"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 17,
        "title": "🔍 RADIUS Специфичные Метрики",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
        "collapsed": false
      },
      {
        "id": 18,
        "title": "RADIUS Пакеты",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum by (operation, direction) (rate(radius_packets_total{instance=~\"$instance\"}[5m]))",
            "legendFormat": "{{operation}} {{direction}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "pps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {
                "mode": "none",
                "group": "A"
              },
              "axisPlacement": "auto",
              "axisLabel": "",
              "axisColorMode": "text",
              "scaleDistribution": {
                "type": "linear"
              },
              "axisCenteredZero": false,
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "thresholdsStyle": {
                "mode": "off"
              }
