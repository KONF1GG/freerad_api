          "h": 8,
          "w": 12,
          "x": 0,
          "y": 59
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(radius_traffic_bytes_bucket[5m]))",
            "legendFormat": "95th percentile {{direction}} {{auth_type}}",
            "refId": "A",
