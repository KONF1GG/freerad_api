      {
        "title": "Alert Panels",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 67
        },
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Critical Metrics Alert Table",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 68
        },
        "targets": [
          {
            "expr": "rate(radius_errors_total[5m]) > 0.1",
            "legendFormat": "High Error Rate",
            "refId": "A",
            "datasource": "${datasource}"
          },
          {
            "expr": "http_requests_queue_size > 10",
            "legendFormat": "High Queue Size",
            "refId": "B",
            "datasource": "${datasource}"
          },
          {
            "expr": "histogram_quantile(0.95, rate(radius_operation_duration_bucket[5m])) > 5",
            "legendFormat": "High Operation Latency",
            "refId": "C",
            "datasource": "${datasource}"
          },
          {
            "expr": "radius_redis_available_permits < 5",
            "legendFormat": "Low Redis Permits",
            "refId": "D",
            "datasource": "${datasource}"
          }
        ],
        "options": {
          "showHeader": true
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "5s",
    "schemaVersion": 30,
    "version": 1,
    "links": [],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "label": "Data Source",
          "description": "Select Prometheus datasource",
          "current": {
            "selected": true,
            "text": "Prometheus",
            "value": "Prometheus"
          },
          "refresh": 1,
          "regex": "",
          "hide": 0
        },
        {
          "name": "instance",
          "type": "query",
          "datasource": "${datasource}",
          "query": "label_values(up{job=\"radius-core\"}, instance)",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".*",
          "multi": true
        },
        {
          "name": "auth_type",
          "type": "query",
          "datasource": "${datasource}",
          "query": "label_values(radius_packets_total, auth_type)",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".*",
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Service Down Events",
          "datasource": "${datasource}",
          "enable": true,
          "expr": "up{job=\"radius-core\"} == 0",
          "iconColor": "red"
        }
      ]
    }
}