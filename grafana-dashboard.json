{
    "id": null,
    "title": "RADIUS Core Service Monitoring",
    "tags": ["radius", "microservice", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Service Overview",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "collapsed": false,
        "panels": []
      },
      {
        "title": "Service Status",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 1
        },
        "targets": [
          {
            "expr": "up{job=\"radius-core\"}",
            "refId": "A",
            "datasource": "${datasource}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "DOWN"
                  },
                  "1": {
                    "text": "UP"
                  }
                },
                "type": "value"
              }
            ]
          }
        }
      },
      {
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 1
        },
        "targets": [
          {
            "expr": "radius_active_sessions",
            "refId": "A",
            "datasource": "${datasource}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        }
      },
      {
        "title": "HTTP Queue Size",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 1
        },
        "targets": [
          {
            "expr": "http_requests_queue_size",
            "refId": "A",
            "datasource": "${datasource}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "title": "Requests Per Second",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 1
        },
        "targets": [
          {
            "expr": "rate(radius_requests_per_second_total[1m])",
            "refId": "A",
            "datasource": "${datasource}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "reqps"
          }
        }
      },
      {
        "title": "RADIUS Traffic & Performance",
        "type": "row",
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 5
        },
        "collapsed": false,
        "panels": []
      },
      {
        "title": "RADIUS Packets Rate",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 6
        },
        "targets": [
          {
            "expr": "rate(radius_packets_total[5m])",
            "legendFormat": "{{operation}} {{direction}} {{auth_type}}",
            "refId": "A",
            "datasource": "${datasource}"
          }
        ],
        "yAxes": [
          {
            "unit": "pps",
            "min": 0
          }
        ],
        "legend": {
          "avg": false,
          "current": false,
          "max": false,
          "min": false,
          "show": true,
          "total": false,
          "values": false
        }
      },
      {
        "title": "Accounting Packets Rate",
        "type": "graph",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 6
        },
