{
  "dashboard": {
    "id": null,
    "title": "RADIUS Core Service Metrics",
    "tags": ["radius", "microservice", "performance"],
    "style": "dark",
    "timezone": "browser",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{path}}",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "HTTP Response Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile", 
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "HTTP Status Codes",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(http_responses_total[5m])",
            "legendFormat": "{{status_class}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active HTTP Requests",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "http_requests_active",
            "legendFormat": "{{method}} {{path}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "RADIUS Packet Processing Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(radius_packets_total[5m])",
            "legendFormat": "{{operation}} {{direction}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "RADIUS Accounting Packets by Type",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(radius_accounting_packets_total[5m])",
            "legendFormat": "{{packet_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "Redis Connection Pool",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "radius_redis_available_permits",
            "legendFormat": "Available permits",
            "refId": "A"
          },
          {
            "expr": "radius_redis_waiting_tasks",
            "legendFormat": "Waiting tasks",
            "refId": "B"
          },
          {
            "expr": "radius_redis_max_connections",
            "legendFormat": "Max connections",
            "refId": "C"
          }
        ]
      },
      {
        "id": 8,
        "title": "External Service Call Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(radius_external_call_duration_bucket[5m]))",
            "legendFormat": "95th percentile {{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 9,
        "title": "System Resources",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "process_memory_rss_bytes / 1024 / 1024",
            "legendFormat": "Memory RSS (MB)",
            "refId": "A"
          },
          {
            "expr": "process_cpu_percent",
            "legendFormat": "CPU %",
            "refId": "B"
          }
        ]
      },
      {
        "id": 10,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(radius_errors_total[5m])",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 11,
        "title": "Session Lifecycle Events",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 24},
        "targets": [
          {
            "expr": "rate(radius_session_lifecycle_total[5m])",
            "legendFormat": "{{event}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 12,
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "radius_active_sessions",
            "legendFormat": "{{auth_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 13,
        "title": "Traffic Volume",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24},
        "targets": [
          {
            "expr": "rate(radius_traffic_bytes_sum[5m])",
            "legendFormat": "{{direction}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      }
    ]
  }
}
